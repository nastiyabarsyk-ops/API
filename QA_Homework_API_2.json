    {
      "name": "2. Create Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "// сохрани id задачи\r",
              "pm.environment.set(\"taskId\", jsonData.data.id);\r",
              "\r",
              "// проверка имени\r",
              "pm.test(\"Task name is correct\", function () {\r",
              "    pm.expect(jsonData.data.name).to.eql(\"Test task\");\r",
              "});\r",
              "\r",
              "// проверка ответственного\r",
              "pm.test(\"Responsible is correct\", function () {\r",
              "    pm.expect(jsonData.data.responsible.id).to.exist;\r",
              "});\r",
              "\r",
              "// проверка статуса\r",
              "pm.test(\"Status exists\", function () {\r",
              "    pm.expect(jsonData.data.status).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
