    {
      "name": "2. Create Task",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "// сохраняем id задачи\r",
              "pm.collectionVariables.set(\"task_id\", jsonData.data.id);\r",
              "\r",
              "// проверка имени\r",
              "pm.test(\"Название задачи\", function () {\r",
              "    pm.expect(jsonData.data.name).to.eql(pm.collectionVariables.get(\"task_name\"));\r",
              "});\r",
              "\r",
              "// проверка ответственного\r",
              "pm.test(\"Ответственный\", function () {\r",
              "    pm.expect(String(jsonData.data.responsible.id))\r",
              "      .to.eql(String(pm.collectionVariables.get(\"ivan_id\")));\r",
              "});\r",
              "\r",
              "// проверка статуса\r",
              "pm.test(\"Статус задачи\", function () {\r",
              "    pm.expect(jsonData.data.status).to.eql(\"assigned\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {}
      },
      "request": {
